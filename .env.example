# Conexão Neon Postgres (peça em https://console.neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require"

# Senha do painel admin (escolha algo forte)
ADMIN_PASSWORD="troque-esta-senha"

# Segredo usado para assinar o cookie de sessão admin (qualquer string aleatória longa)
ADMIN_SESSION_SECRET="gere-uma-string-aleatoria-longa-aqui"
